generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model DecisionRecord {
  id                Int      @id @default(autoincrement())
  timestamp         DateTime @default(now())
  emergencyType     String
  bestHospitalName  String
  bestHospitalScore Int
  reasoning         String
}
